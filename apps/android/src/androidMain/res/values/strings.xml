<?xml version="1.0" encoding="utf-8"?>
<!--
  PR-D2a (2026-05-17): user-facing snackbar copy for the voice / call
  guards that fire when the hybrid transport is on a Limited realtime
  path (REST short-poll). Lives in Android string resources rather
  than hardcoded in Kotlin so a future centralised localisation pass
  can flip these without touching ChatScreen.

  Defaults (this file) are English to match the rest of the app UI,
  which is currently English-only — there is no `values-ru/` yet on
  purpose: Test #53.1 (Vladislav 2026-05-17) showed that adding a
  Russian translation just for D2a made the snackbar disagree with
  the rest of the EN UI on RU-locale devices. When the project does
  a proper localisation pass (full UI string extraction + a real RU
  copy), the Russian translation lands here as `values-ru/strings.xml`
  alongside every other RU string.
-->
<resources>
    <string name="d2a_voice_blocked_limited_realtime">Voice messages are temporarily unavailable in Limited realtime mode. Text messages are still delivered through the fallback channel.</string>
    <string name="d2a_call_blocked_limited_realtime">Calls are temporarily unavailable in Limited realtime mode. Try again later on a stable realtime connection.</string>

    <!--
      PR-C1 (2026-05-17): per-reason call-blocked strings.
      Mapped from CallDisabledReason in ChatScreen.onVoiceCall handler.
      Copy locked by architect (PR-C1 brief, 2026-05-17).
      REALITY_UNPROBED reuses the LIMITED_REALTIME string until PR-C2
      ships a Reality endpoint pool + probe; the user-visible text is
      intentionally identical for now.
      TODO(i18n): mirror these in values-ru/strings.xml
    -->
    <string name="c1_call_blocked_limited_realtime">Calls are temporarily unavailable in Limited realtime mode. Try again later on a stable realtime connection.</string>
    <string name="c1_call_blocked_tor_transport">Calls are not available over Tor.</string>
    <string name="c1_call_blocked_reality_unprobed">Calls are temporarily unavailable in Limited realtime mode. Try again later on a stable realtime connection.</string>
    <string name="c1_call_blocked_no_transport">Calls are not available until a stable connection is established.</string>

    <!--
      PR-M1w (2026-05-18): in-progress guard copy.
      Shown as a Snackbar when the user taps the microphone while a previous
      voice message is still uploading (DefaultMessagingService.sendAudioV2
      returns IllegalStateException with this message).
      TODO(i18n): mirror in values-ru/strings.xml
    -->
    <string name="m1w_voice_still_uploading">A voice message is still uploading. Please wait.</string>
</resources>
