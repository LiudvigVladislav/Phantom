<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Trek 2 Stage 2B-B (C6 review-fix round 5 P1.security/tester):
        signature-level permission that guards the dynamically-registered
        S6 controllable breaker trigger receiver (debug/beta builds only,
        gated by BuildConfig.S6_DEBUG_TRIGGER_ENABLED == "1"). A
        co-installed third-party app on the device CANNOT hold this
        permission because it is signature-scoped to this APK's signing
        certificate. The shell user retains broadcast capability via the
        receiver-permission flag on am broadcast (signature-only on a
        debug build); see docs/tracks/trek2-stage2b-b-tele2-smoke.md for
        the recipe.
    -->
    <permission
        android:name="phantom.android.dev.permission.TRIGGER_S6"
        android:protectionLevel="signature" />
    <uses-permission android:name="phantom.android.dev.permission.TRIGGER_S6" />

    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!--
        Required so PhantomMessagingService can hold a partial CPU wake lock
        and a high-performance Wi-Fi lock for the lifetime of its foreground
        notification. Without this, some OEM Android builds suspend the Wi-Fi
        radio after ~60 s even with a foreground service active, which makes
        the WebSocket appear dead from the relay's side and forces a
        client-driven reconnect every minute.
    -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
        ADR-011: AlarmManager-driven periodic wakeup to recover the
        WebSocket from OEM Wi-Fi-radio parking (Tecno HiOS et al.). Both
        permissions are declared so we cover the full API range:

        SCHEDULE_EXACT_ALARM is required by Android 12 (API 31) for
        setExactAndAllowWhileIdle(). Granted automatically at install.

        USE_EXACT_ALARM is required by Android 13+ (API 33+) for the same
        API. Messenger apps (which PHANTOM is) qualify under Play Console
        policy and the permission is granted without a user prompt — but
        users can still revoke it in Settings, in which case
        AlarmManager.canScheduleExactAlarms() returns false and the
        scheduling code falls back to setAndAllowWhileIdle (Doze-aware
        inexact alarm; ~5-15 min latency instead of 30-60 s).
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!--
        Tier-1 HiOS workaround (PR after ADR-013): MulticastLock keeps
        the Wi-Fi radio out of deep-park on aggressive OEMs. Granted
        automatically at install — no runtime prompt.
    -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!--
        Tier-1 HiOS workaround: ConnectivityManager.requestNetwork()
        from the alarm receiver requires CHANGE_NETWORK_STATE. Granted
        automatically at install — normal-protection-level permission,
        no runtime prompt.
    -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <application
        android:name=".PhantomApplication"
        android:label="PHANTOM"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.Phantom"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="phantom" android:host="invite" />
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="phntm.pro" android:pathPrefix="/invite/" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.PhantomMessagingService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <receiver
            android:name=".notifications.QuickReplyReceiver"
            android:exported="false" />

        <!--
            ADR-011: AlarmManager wakeup target. Fires every ~30-60 s to
            check whether the WebSocket pong is still fresh; forces a
            reconnect via PhantomWakeupReceiver.handleWake() if not.
            Not exported — only our own AlarmManager schedule path can
            invoke it.
        -->
        <receiver
            android:name=".service.PhantomWakeupReceiver"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>
    </application>

</manifest>
