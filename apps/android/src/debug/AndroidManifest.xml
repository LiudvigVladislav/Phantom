<?xml version="1.0" encoding="utf-8"?>
<!--
    Trek 2 Stage 2B-B (C6 review-fix round 10 P1.arch+sec): debug-only
    manifest overlay declaring the S6 controllable breaker trigger
    Activity. Round-9 declared it in `androidMain/AndroidManifest.xml`
    which left the component enumerable via `pm list packages -f` and
    `dumpsys package` on release APKs even though the runtime gates
    would refuse to dispatch.

    Round 10 manifest-surface review flagged this as a regression
    vs the round 3-8 dynamic-receiver approach (which never existed
    in release manifests). This overlay restores the round 3-8
    invariant: the activity exists ONLY in debug-variant APKs.

    Release builds still pin BuildConfig.S6_DEBUG_TRIGGER_ENABLED to
    "0" as a defence-in-depth backstop; the orchestrator constructor
    gate (s6DebugTriggerEnabled = false in release) is the load-
    bearing third layer.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!--
            Trek 2 Stage 2B-B (C6 review-fix round 10): the
            activity is gated on
            android.permission.INTERACT_ACROSS_USERS_FULL. The
            permission is held by the shell uid (which is what
            `adb shell am start` runs as) and is signature-scoped
            to the system signing certificate, so co-installed
            third-party apps cannot satisfy it. Verified at the
            wire on TECNO BF7-12 (round 10): `am start` from the
            shell uid 2000 launches the activity cleanly; all four
            expected logcat lines (S6 invocation, trigger fired,
            breaker open, dispatched=true) emit within ~15 ms.
            See docs/tracks/trek2-stage2b-b-tele2-smoke.md for the
            full smoke recipe and field-evidence requirements.
        -->
        <activity
            android:name="phantom.android.dev.S6BreakerTriggerActivity"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.NoDisplay" />
    </application>

</manifest>
