# Claude Code
.claude/settings.local.json
# Local Claude Code skills / plugins (per-user dev tooling — not part of the
# project source). Tracked variants (project-level skills/agents/commands)
# live elsewhere under .claude/ and are added explicitly when needed.
.claude/skills/

# Gradle / KMP
.gradle/
build/
*.gradle.kts.bak
local.properties
*.iml
.idea/

# Android
apps/android/local.properties
*.apk
*.aab

# Briar tor + lyrebird native binaries — extracted at build time from
# org.briarproject:tor-android.jar and lyrebird-android.jar by the
# `unpackTorBinaries` task in shared/core/transport/build.gradle.kts.
# Generated, not source.
shared/core/transport/src/androidMain/jniLibs/

# iOS
apps/ios/Pods/
apps/ios/*.xcworkspace
apps/ios/DerivedData/
*.ipa

# Node / Next.js (prototype)
node_modules/
.next/
prototype/web/.next/
prototype/web/node_modules/
prototype/web/out/

# Environment / secrets
.env
.env.*
*.pem
*.key
secrets/

# Keystores — NEVER commit (loss = cannot update app in Play Store)
*.jks
*.keystore
*.p12
*.pfx
keystores/*
!keystores/README.md
signing.properties

# OS
.DS_Store
Thumbs.db

# Rust / Cargo build artifacts
services/target/
target/

# Relay runtime persistence (jsonl append-only state — regenerated from
# wire on next publish). Same family as reports.jsonl / blocklist.txt
# already kept out of git.
services/relay/prekeys.jsonl
services/relay/reports.jsonl
services/relay/blocklist.txt

# Logs
*.log
npm-debug.log*
