# Internal sprint-planning docs — local-only working area for the
# solo maintainer's day-to-day execution notes. The public face of the
# project (formal milestones, roadmap, decisions log, architecture
# specs) lives in `docs/project/` and is tracked. See
# `docs/project/README.md` for the split convention.
docs/internal/

# Claude Code
.claude/settings.local.json
# Local Claude Code skills / plugins (per-user dev tooling — not part of the
# project source). Tracked variants (project-level skills/agents/commands)
# live elsewhere under .claude/ and are added explicitly when needed.
.claude/skills/
# Per-user MCP server configuration (Claude Code).
.mcp.json

# Gradle / KMP
.gradle/
build/
*.gradle.kts.bak
local.properties
*.iml
.idea/
# Kotlin Multiplatform / KSP per-module metadata cache. Regenerated on
# every clean build; bloats the repo when committed (76 .klib files
# observed before this gitignore landed).
.kotlin/

# Android
apps/android/local.properties
*.apk
*.aab
# Firebase config — defensive ignore. PHANTOM does not use Firebase
# (FCM was removed 2026-05-14 to align the code with the "no Big Tech
# metadata" stance documented in KNOWN_ISSUES § ISSUE-001 and ADR-001).
# This entry prevents accidental commit of credentials if anyone ever
# experiments with Firebase tooling locally.
apps/android/google-services.json

# Briar tor + lyrebird native binaries — extracted at build time from
# org.briarproject:tor-android.jar and lyrebird-android.jar by the
# `unpackTorBinaries` task in shared/core/transport/build.gradle.kts.
# Generated, not source.
shared/core/transport/src/androidMain/jniLibs/

# iOS
apps/ios/Pods/
apps/ios/*.xcworkspace
apps/ios/DerivedData/
*.ipa

# Node / Next.js (prototype)
node_modules/
.next/
prototype/web/.next/
prototype/web/node_modules/
prototype/web/out/

# Environment / secrets
.env
.env.*
*.pem
*.key
secrets/

# Keystores — NEVER commit (loss = cannot update app in Play Store)
*.jks
*.keystore
*.p12
*.pfx
keystores/*
!keystores/README.md
signing.properties

# OS
.DS_Store
Thumbs.db

# Rust / Cargo build artifacts
services/target/
target/

# Relay runtime persistence (jsonl append-only state — regenerated from
# wire on next publish). Same family as reports.jsonl / blocklist.txt
# already kept out of git.
services/relay/prekeys.jsonl
services/relay/reports.jsonl
services/relay/blocklist.txt

# Logs
*.log
npm-debug.log*
deploy/bridge2/.env

# Xray REALITY server (Stage 5E.A) — secret material lives only on the VPS.
# config.json is rendered from config.json.template + .env at deploy time.
deploy/xray/.env
deploy/xray/config.json

# Local working files (operator scratch — not project source).
tag-message.txt

# Private operator material — drafts of any external-funding
# applications live here, not in the public tracker. Created
# 2026-05-08 to hold a draft moved out of docs/project/.
private/

# PDF working drafts (kept locally, never pushed). Two exceptions retain
# the legitimate published-PDF locations under legal/assets/ and docs/**.
*.pdf
!legal/assets/*.pdf
!docs/**/*.pdf
