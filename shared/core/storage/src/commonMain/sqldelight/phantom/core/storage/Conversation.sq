CREATE TABLE conversation (
    id TEXT NOT NULL PRIMARY KEY,
    their_username TEXT NOT NULL,
    their_public_key_hex TEXT NOT NULL,
    last_message_preview TEXT,
    last_message_at INTEGER,
    unread_count INTEGER NOT NULL DEFAULT 0,
    trust_tier TEXT NOT NULL DEFAULT 'TRUSTED',
    blocked INTEGER NOT NULL DEFAULT 0,
    notes TEXT DEFAULT NULL,
    is_verified INTEGER NOT NULL DEFAULT 0,
    disappearing_timer_secs INTEGER NOT NULL DEFAULT 0,
    archived INTEGER NOT NULL DEFAULT 0,
    identity_key_changed_at INTEGER,
    muted_until INTEGER,
    pinned INTEGER NOT NULL DEFAULT 0,
    -- Set by the Alpha 1 → Alpha 2 migration (PR C, ADR-009): every
    -- existing conversation whose Alpha 1 ratchet state was wiped during
    -- the cryptographic protocol upgrade gets this flag = 1. The chat
    -- list shows a "needs re-handshake" indicator and the next outbound
    -- message in such a conversation forces the X3DH 4-DH bootstrap
    -- path. Cleared after a successful new session is established.
    needs_rehandshake INTEGER NOT NULL DEFAULT 0
);

getAllConversations:
SELECT * FROM conversation ORDER BY pinned DESC, last_message_at DESC;

getActiveConversations:
SELECT * FROM conversation
WHERE blocked = 0 AND trust_tier = 'TRUSTED' AND their_public_key_hex != '' AND archived = 0
ORDER BY pinned DESC, last_message_at DESC;

getMessageRequests:
SELECT * FROM conversation
WHERE blocked = 0 AND trust_tier = 'REQUEST'
ORDER BY last_message_at DESC;

getConversation:
SELECT * FROM conversation WHERE id = ?;

upsertConversation:
INSERT OR REPLACE INTO conversation(
    id, their_username, their_public_key_hex,
    last_message_preview, last_message_at, unread_count,
    trust_tier, blocked, notes,
    is_verified, disappearing_timer_secs, archived,
    identity_key_changed_at, muted_until, pinned,
    needs_rehandshake
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

setNeedsRehandshake:
UPDATE conversation SET needs_rehandshake = :flag WHERE id = :id;

markAllNeedsRehandshake:
UPDATE conversation SET needs_rehandshake = 1;

updateNotes:
UPDATE conversation SET notes = ? WHERE id = ?;

incrementUnread:
UPDATE conversation SET unread_count = unread_count + 1 WHERE id = ?;

resetUnread:
UPDATE conversation SET unread_count = 0 WHERE id = ?;

getBlockedConversations:
SELECT * FROM conversation WHERE blocked = 1 ORDER BY their_username ASC;

blockConversation:
UPDATE conversation SET blocked = 1 WHERE id = ?;

unblockConversation:
UPDATE conversation SET blocked = 0 WHERE id = ?;

acceptRequest:
UPDATE conversation SET trust_tier = 'TRUSTED' WHERE id = ?;

deleteConversation:
DELETE FROM conversation WHERE id = ?;

setVerified:
UPDATE conversation SET is_verified = :isVerified WHERE id = :id;

setDisappearingTimer:
UPDATE conversation SET disappearing_timer_secs = :secs WHERE id = :id;

getDisappearingTimer:
SELECT disappearing_timer_secs FROM conversation WHERE id = :id;

archiveConversation:
UPDATE conversation SET archived = 1 WHERE id = ?;

unarchiveConversation:
UPDATE conversation SET archived = 0 WHERE id = ?;

getArchivedConversations:
SELECT * FROM conversation WHERE archived = 1 ORDER BY last_message_at DESC;

setIdentityKeyChangedAt:
UPDATE conversation SET identity_key_changed_at = :ts, is_verified = 0 WHERE id = :id;

clearIdentityKeyChangedAt:
UPDATE conversation SET identity_key_changed_at = NULL WHERE id = :id;

setMutedUntil:
UPDATE conversation SET muted_until = :until WHERE id = :id;

setPinned:
UPDATE conversation SET pinned = :pinned WHERE id = :id;
