{
  "env": {
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "0"
  },
  "permissions": {
    "allow": [
      "Bash(./gradlew :shared:core:transport:compileDebugKotlinAndroid)",
      "Bash(grep -nA2 \"getActiveConversations:\" shared/core/storage/src/commonMain/sqldelight/phantom/core/storage/Conversation.sq)",
      "Bash(./gradlew :shared:core:messaging:compileDebugKotlinAndroid)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'Session start checklist:\n- Read docs/doctrine and ADRs\n- Stay within Alpha-0 scope\n- Prefer thin vertical slices\n'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf 'Before finishing, confirm:\n- tests added or updated\n- scope not expanded\n- docs updated if contracts changed\n'"
          }
        ]
      }
    ]
  }
}
