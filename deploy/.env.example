# Copy to .env before running `docker compose up`.
# Do NOT commit .env to git (.gitignore already covers deploy/.env).

# --- Relay configuration (all optional — defaults shown) ----------------------

# Host and port the relay binds inside the container.
# Leave defaults unless you also change docker-compose.yml expose/ports.
RELAY_HOST=0.0.0.0
RELAY_PORT=8080

# Max envelope payload in bytes. 1 MB accommodates voice notes up to ~30 s,
# which Alpha 1 inlines as base64 inside the encrypted text payload (~67 KB
# per 5 s of 3GP audio). Lower this only if you're not using voice messages.
# Larger media (files, longer audio) will move to a separate attachment
# service (MinIO) in a later milestone.
RELAY_MAX_PAYLOAD_BYTES=1048576

# How long an undelivered envelope is kept (seconds). 7 days is reasonable for
# intermittent offline devices. Increase if a customer needs longer retention.
RELAY_ENVELOPE_TTL_SECS=604800

# Per-recipient queue cap. Above this, older envelopes are dropped.
RELAY_MAX_ENVELOPES_PER_RECIPIENT=500

# Rate limit — max SEND messages per sender identity per window.
RELAY_RATE_LIMIT_PER_WINDOW=60
RELAY_RATE_LIMIT_WINDOW_SECS=60

# --- Secrets (leave unset for open dev, set for closed alpha) ------------------

# When set, every WebSocket /ws connection must supply ?token=<value>.
# Generate once with: openssl rand -hex 32
# Then bake into the Android release build via the RELAY_TOKEN build field.
# RELAY_SECRET_TOKEN=

# Firebase Cloud Messaging legacy server key. Leave unset to disable FCM wake
# (relay will still deliver on reconnect; only the silent-push wake is skipped).
# RELAY_FCM_SERVER_KEY=
