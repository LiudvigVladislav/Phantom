# PHANTOM Caddy configuration.
#
# Two virtual hosts:
#   relay.phntm.pro — reverse-proxy WebSocket + HTTP to the relay container.
#                     Cloudflare is set to DNS-only for this host; Caddy
#                     handles TLS via Let's Encrypt directly (WebSocket-
#                     friendly).
#   phntm.pro       — static file serving for /.well-known/assetlinks.json
#                     (Android Universal Links) and a placeholder landing.
#                     Cloudflare is Proxied in front of this host.

{
    # Global options.
    # Email for Let's Encrypt account + cert renewal notices.
    email hello@phntm.pro
    # Turn off automatic HTTPS redirect for /health to keep uptime probes cheap,
    # but still serve over TLS.
    # (Caddy auto-HTTPS is on by default; this is just the admin email.)
}

# -----------------------------------------------------------------------------
# relay.phntm.pro — WebSocket + HTTP relay
# -----------------------------------------------------------------------------
relay.phntm.pro {
    # Enforce HSTS (12 months) — once a client hits this host over TLS,
    # the browser/app remembers and refuses plaintext fallback.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Relay serves no HTML, so CSP/X-Frame-Options are defense-in-depth.
        X-Content-Type-Options "nosniff"
        X-Frame-Options        "DENY"
        Referrer-Policy        "no-referrer"
        # Remove Caddy's default Server banner to reveal less about the stack.
        -Server
    }

    # Reverse-proxy everything to the relay container on the internal network.
    # Caddy upgrades WebSocket connections automatically; no special `@ws`
    # matcher is needed in v2.
    reverse_proxy relay:8080 {
        # Forward the real client IP so the relay's rate limiter can key on it.
        header_up X-Real-IP        {remote_host}
        header_up X-Forwarded-For  {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Disable proxy-side timeouts so a quiet WebSocket session does not
        # get killed mid-conversation. Heartbeats are handled at the
        # application level (RelayTransportConfig.PING_INTERVAL_MS) and at
        # the WS protocol level (Ktor pingIntervalMillis); Caddy must not
        # second-guess them with a 60-second idle close. flush_interval=-1
        # tells Caddy to flush every frame to the upstream immediately,
        # which keeps streaming WS frames responsive on slow cellular.
        transport http {
            read_timeout  0
            write_timeout 0
            dial_timeout  10s
        }
        flush_interval -1
    }

    # Structured access log — method + path only. No query string, no body.
    # Matches the relay's in-process TraceLayer policy (never logs ?token=).
    log {
        output stdout
        format json
        level  INFO
    }
}

# -----------------------------------------------------------------------------
# ntfy.phntm.pro — UnifiedPush distributor (ADR-016)
# -----------------------------------------------------------------------------
# Self-hosted ntfy serves the wake-up channel for the PHANTOM hybrid
# transport. Caddy terminates TLS at the edge; the ntfy container itself
# only listens plaintext on port 80 inside the phantom-internal network.
#
# Cloudflare configuration: DNS-only for this host (orange cloud OFF).
# Caddy completes the HTTP-01 ACME challenge directly with Let's Encrypt;
# proxying through Cloudflare would interfere with WebSocket upgrade and
# is unnecessary because Cloudflare provides no value for a server-to-
# server push API consumed only by PHANTOM relay + PHANTOM client.
ntfy.phntm.pro {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options        "DENY"
        Referrer-Policy        "no-referrer"
        # ntfy bundled web UI loads fonts.googleapis.com (issue #554).
        # We disable the UI in server.yml (web-root: "disable") so it
        # never serves to a browser, but lock down CSP defense-in-depth
        # in case a misconfiguration ever re-enables it.
        Content-Security-Policy "default-src 'none'; connect-src 'self'"
        -Server
    }

    reverse_proxy ntfy:80 {
        # Forward client IP for ntfy's per-IP rate limiter.
        header_up X-Real-IP        {remote_host}
        header_up X-Forwarded-For  {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # ntfy uses long-lived HTTP for subscriptions (Server-Sent
        # Events). Same WSS-style timeout disable as the relay vhost
        # so subscribed clients aren't kicked.
        transport http {
            read_timeout  0
            write_timeout 0
            dial_timeout  10s
        }
        flush_interval -1
    }

    log {
        output stdout
        format json
        level  INFO
    }
}

# -----------------------------------------------------------------------------
# bridge.phntm.pro — operator-controlled WebTunnel bridge (ADR-018 Stage 5C)
# -----------------------------------------------------------------------------
# Tor pluggable transport: WebTunnel makes Tor circuit traffic look like
# regular HTTPS WebSocket traffic to a normal-looking website. PHANTOM
# clients in censored networks (РФ / Иран / Китай) connect here when public
# Snowflake brokers are blocked.
#
# Architecture:
#   client → bridge.phntm.pro/<secret-path>      (HTTPS WebSocket upgrade)
#          → caddy reverse_proxy
#          → webtunnel-bridge:15000               (PT listener inside docker)
#          → tor bridge relay
#          → tor entry guard (clearnet egress)   → … → onion service
#
# The "secret path" must match the WEBTUNNEL_URL env var passed to the
# webtunnel-bridge container. Anyone hitting any other path on this
# domain sees the placeholder landing — making the bridge look like a
# normal small website to scanners.
#
# Cloudflare configuration: DNS-only for this host (orange cloud OFF).
# The WebSocket upgrade through Cloudflare's WS proxy adds a chain that
# could be fingerprinted; bridges work better with a direct path. Caddy
# completes HTTP-01 ACME with Let's Encrypt directly.
#
# Operator setup steps in deploy/webtunnel-bridge-setup.md.
# -----------------------------------------------------------------------------
bridge.phntm.pro {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options        "DENY"
        Referrer-Policy        "no-referrer"
        -Server
    }

    # WebTunnel secret path — the URL fragment after the domain that the
    # PT client sends. Configured per-deploy via the WEBTUNNEL_SECRET_PATH
    # env var (Caddy reads it via {$WEBTUNNEL_SECRET_PATH}). Path is the
    # bridge's "shared secret" with clients; rotating it invalidates the
    # `OperatorBridges.kt` entry until the client APK is republished.
    @webtunnel path /{$WEBTUNNEL_SECRET_PATH}
    handle @webtunnel {
        reverse_proxy webtunnel-bridge:15000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            transport http {
                read_timeout  0
                write_timeout 0
                dial_timeout  10s
            }
            flush_interval -1
        }
    }

    # Everything else: serve a tiny placeholder so a casual scan of
    # bridge.phntm.pro looks like a small static site, not an empty 404.
    # Defence-in-depth — TSPU operators sometimes fingerprint "domain
    # exists but only serves 404" as suspicious.
    handle {
        root * /srv/webtunnel-landing
        try_files {path} /index.html
        file_server
    }

    log {
        output stdout
        format json
        level  INFO
    }
}

# -----------------------------------------------------------------------------
# phntm.pro — assetlinks.json + placeholder landing
# -----------------------------------------------------------------------------
# NOTE on Cloudflare:
# For the first `docker compose up`, temporarily set the phntm.pro A record
# to "DNS only" in Cloudflare so Caddy can complete the HTTP-01 ACME challenge.
# Once the cert is issued (check /data/caddy/certificates/ in the caddy-data
# volume), re-enable the orange cloud. Full (strict) mode in Cloudflare will
# then accept Caddy's Let's Encrypt cert.
# Alternative: use DNS-01 via Cloudflare API — see deploy/README.md.

phntm.pro, www.phntm.pro {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    # FLOSS/fund machine-readable proof of funding-manifest ownership.
    # Plain text, one URL per line — NOT JSON. Must be served with
    # text/plain so strict spec consumers do not reject it. Matched
    # before the generic /.well-known/* handler below, because Caddy
    # evaluates handle blocks in source order.
    handle /.well-known/funding-manifest-urls {
        rewrite * /funding-manifest-urls
        root * /srv/well-known
        header Content-Type "text/plain; charset=utf-8"
        file_server
    }

    # Android App Links + Apple Universal Links live under /.well-known/.
    # Android requires Content-Type: application/json on assetlinks.json.
    handle_path /.well-known/* {
        root   * /srv/well-known
        header Content-Type application/json
        file_server
    }

    # Static assets for the legal pages — currently the PHANTOM logo used
    # in the header / footer of /terms and /privacy. Source-of-truth lives
    # at `legal/assets/` in the repo, mounted read-only at /srv/legal/assets.
    handle_path /assets/* {
        root * /srv/legal/assets
        file_server
    }

    # funding.json — fundingjson.org / FLOSS-fund machine-readable funding
    # manifest. Source of truth is the repo-root `funding.json` (mounted
    # read-only into the caddy container at /srv/funding/ — see
    # docker-compose.yml). Served with `application/json` content type,
    # `Access-Control-Allow-Origin: *` (open manifest is meant to be read
    # cross-origin by crawlers and funding-aggregator UIs), and a 1-hour
    # cache TTL (manifest changes are rare; a stale-by-an-hour fetch is
    # acceptable and reduces hits on every aggregator scan).
    handle /funding.json {
        root * /srv/funding
        header Content-Type "application/json; charset=utf-8"
        header Access-Control-Allow-Origin "*"
        header Cache-Control "public, max-age=3600"
        file_server
    }

    # Russian-locale routes MUST come before the generic English routes —
    # Caddy matches `handle_path` blocks in source order, and `/terms*`
    # would otherwise swallow `/terms/ru` before this block sees it.

    # Terms of Service (Russian) — generated by legal/render.py from
    # TERMS_OF_SERVICE_RU.md.
    handle_path /terms/ru* {
        root * /srv/legal
        rewrite * /terms-ru.html
        header Content-Type "text/html; charset=utf-8"
        file_server
    }

    # Privacy Policy (Russian).
    handle_path /privacy/ru* {
        root * /srv/legal
        rewrite * /privacy-ru.html
        header Content-Type "text/html; charset=utf-8"
        file_server
    }

    # Terms of Service (English, default) — themed HTML page generated by
    # `legal/render.py` from TERMS_OF_SERVICE_EN.md. The OnboardingScreen
    # "Read full Terms" link points here. Each rendered page carries a
    # language switcher in the header that links to the /ru variants
    # above.
    handle_path /terms* {
        root * /srv/legal
        rewrite * /terms.html
        header Content-Type "text/html; charset=utf-8"
        file_server
    }

    # Privacy Policy (English, default) — same model as /terms.
    handle_path /privacy* {
        root * /srv/legal
        rewrite * /privacy.html
        header Content-Type "text/html; charset=utf-8"
        file_server
    }

    # SEO: sitemap.xml served from the site bind-mount with correct Content-Type.
    handle /sitemap.xml {
        root * /srv/landing
        header Content-Type "application/xml; charset=utf-8"
        header Cache-Control "public, max-age=3600"
        file_server
    }

    # SEO: robots.txt served from the site bind-mount with correct Content-Type.
    # Note: Cloudflare may inject its own robots.txt at edge — verify with
    # `curl https://phntm.pro/robots.txt` after deploy; may need to disable
    # Cloudflare-managed robots.txt in Dashboard if it overrides.
    handle /robots.txt {
        root * /srv/landing
        header Content-Type "text/plain; charset=utf-8"
        header Cache-Control "public, max-age=3600"
        file_server
    }

    # Static site for phntm.pro served from `site/` bind-mount.
    # `try_files {path} {path}/index.html =404` serves real 404 for unknown URLs
    # instead of soft-404 falling back to index.html (which was causing every
    # non-existent path to return homepage HTML — bad for SEO crawl budget).
    handle {
        root * /srv/landing
        try_files {path} {path}/index.html =404
        file_server
    }

    log {
        output stdout
        format json
        level  INFO
    }
}
